rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each user's private tasks and drafts — only readable by that user
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Shared family task list — any signed-in user can read and write
    match /familyTasks/{taskId} {
      allow read, write: if request.auth != null;
    }

    // Shared Anthropic API key — any signed-in user can read or update it
    match /config/app {
      allow read, write: if request.auth != null;
    }
  }
}
